<T3DataStructure>
    <meta>
        <langDisable>1</langDisable>
    </meta>
    <sheets>
        <sDEF>
            <ROOT>
                <TCEforms>
                    <sheetTitle>LLL:EXT:person/Resources/Private/Language/locallang_flexform.xlf:sheet_person</sheetTitle>
                </TCEforms>
                <type>array</type>
                <el>                          
                    
                    <settings.pages>
                        <label>LLL:EXT:person/Resources/Private/Language/locallang_flexform.xlf:startingpoint</label>
                        <onChange>reload</onChange>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>3</size>
                            <maxitems>10</maxitems>
                            <minitems>0</minitems>
                            <suggestOptions>
                                <default>
                                    <searchWholePhrase>1</searchWholePhrase>
                                </default>
                            </suggestOptions>
                        </config>
                    </settings.pages>
                    
                    <settings.itemPerPage>
                        <TCEforms>
                            <exclude>0</exclude>
                            <label>LLL:EXT:person/Resources/Private/Language/locallang_flexform.xlf:itemPerPage</label>
                            <config>
                                <type>input</type>
                                <size>1</size>
                                <default>10</default>
                                <eval>int</eval>
                                <range>
                                    <lower>1</lower>
                                    <upper>100</upper>
                                </range>
                                <wizards>
                                    <slideshow>
                                        <type>slider</type>
                                        <step>1</step>
                                    </slideshow>
                                </wizards>
                            </config> 
                        </TCEforms>
                    </settings.itemPerPage>
                    <settings.maximumLinks>
                        <TCEforms>
                            <exclude>0</exclude>
                            <label>LLL:EXT:person/Resources/Private/Language/locallang_flexform.xlf:maximumLinks</label>
                            <config>
                                <type>input</type>
                                <size>1</size>
                                <default>10</default>
                                <eval>int</eval>
                                <range>
                                    <lower>1</lower>
                                    <upper>100</upper>
                                </range>
                                <wizards>
                                    <slideshow>
                                        <type>slider</type>
                                        <step>1</step>
                                    </slideshow>
                                </wizards>
                            </config> 
                        </TCEforms>
                    </settings.maximumLinks> 
               </el>     
            </ROOT>
        </sDEF>     
    </sheets>
</T3DataStructure>
